# --- Servidor ---
# Puerto 3002: pagos-api usa 3001 (banco). No compartir el mismo PORT.
PORT=3002
NODE_ENV=development
SWAGGER_PATH=docs

# --- SQL Server (deben ser los MISMOS valores del .env del Express viejo) ---
SERVER_BD=
NAME_BD=
USER_BD=
PASSWORD_BD=

# --- Pool mssql ---
MSSQL_REQUEST_TIMEOUT=300000
MSSQL_ENCRYPT=false
MSSQL_TRUST_SERVER_CERTIFICATE=true
MSSQL_ENABLE_ARITH_ABORT=true

# --- CORS ---
CORS_ORIGIN=*
