# --- Servidor ---
# Puerto 3002: pagos-api usa 3001 (banco). No compartir el mismo PORT.
PORT=3002
NODE_ENV=development
SWAGGER_PATH=docs

# --- SQL Server (deben ser los MISMOS valores del .env del Express viejo) ---
SERVER_BD=
NAME_BD=
USER_BD=
PASSWORD_BD=

# --- Pool mssql ---
MSSQL_REQUEST_TIMEOUT=300000
MSSQL_ENCRYPT=false
MSSQL_TRUST_SERVER_CERTIFICATE=true
MSSQL_ENABLE_ARITH_ABORT=true

# --- CORS ---
CORS_ORIGIN=*

# --- Emisión RCV ---
# local = INSERT directo Sis2000 (default). external = HTTP La Mundial QA con fallback local.
EMISSION_SOURCE=local
# Plan usado en validateEmissionAuto si el body no trae `plan` (validación pre-plan en Formulario Exélixi).
LAMUNDIAL_PLAN_DEFAULT=RCVBAS
LAMUNDIAL_PRODUCTOR=80080
LAMUNDIAL_CUSUARIO=4
# Tipo pago pago móvil en MABANCO_DESTINO (SysIP usa 3). Solo si maclient_api no trae ctipopago.
LAMUNDIAL_CTIPOPAGO=3
# URL base PDF póliza — una de las dos (mismo valor que Express legacy URLPoliza)
POLICY_PDF_URL=
URLPoliza=https://qaapi.lamundialdeseguros.com/sis2000/poliza/

# Solo si EMISSION_SOURCE=external (no commitear valores reales):
# EXTERNAL_API_URL_AUTO=
# EXTERNAL_API_KEY=
# EXTERNAL_BASIC_AUTH=
